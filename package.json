{
  "name": "opencode-web-integration",
  "displayName": "OpenCode Web Integration",
  "description": "VSCode extension for OpenCode Web (unofficial)",
  "version": "0.1.1",
  "publisher": "hudi",
  "icon": "resources/icons/opencode.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/liangqiangWang/opencode-web-for-vscode"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencode-container",
          "title": "OpenCode-Web",
          "icon": "resources/icons/opencode.svg"
        }
      ]
    },
    "views": {
      "opencode-container": [
        {
          "id": "opencodeWebview",
          "name": "OpenCode",
          "type": "webview",
          "icon": "resources/icons/opencode.svg",
          "themeIcon": {
            "light": "resources/icons/opencode-light.svg",
            "dark": "resources/icons/opencode-dark.svg"
          }
        }
      ]
    },
    "commands": [
      {
        "command": "opencode-web.appendCode",
        "title": "添加到 OpenCode 终端",
        "icon": "$(arrow-right)"
      },
      {
        "command": "opencode-web.openInBrowser",
        "title": "在浏览器中打开",
        "icon": "$(globe)"
      },
      {
        "command": "opencode-web.toggleSidebar",
        "title": "在编辑器中打开",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "opencode-web.openTui",
        "title": "打开 OpenCode 终端",
        "icon": "$(circuit-board)"
      },
      {
        "command": "opencode-web.killProcess",
        "title": "停止进程",
        "icon": "$(x)"
      },
      {
        "command": "opencode-web.restartProcess",
        "title": "重启进程",
        "icon": "$(debug-restart)"
      },
      {
        "command": "opencode-web.refreshWebview",
        "title": "刷新连接",
        "icon": "$(refresh)"
      },
      {
        "command": "opencode-web.showHelp",
        "title": "查看帮助",
        "icon": "$(question)"
      }
    ],
    "submenus": [
      {
        "id": "opencode-web.moreMenu",
        "label": "更多操作",
        "icon": "$(ellipsis)"
      },
      {
        "id": "opencode-web.processManagementMenu",
        "label": "进程管理"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "opencode-web.refreshWebview",
          "when": "view == opencodeWebview",
          "group": "navigation@1"
        },
        {
          "command": "opencode-web.openTui",
          "when": "view == opencodeWebview",
          "group": "navigation@2"
        },
        {
          "submenu": "opencode-web.moreMenu",
          "when": "view == opencodeWebview",
          "group": "navigation@3"
        }
      ],
      "editor/title": [
        {
          "command": "opencode-web.openTui",
          "group": "navigation",
          "icon": "resources/icons/opencode.svg",
          "themeIcon": {
            "light": "resources/icons/opencode-light.svg",
            "dark": "resources/icons/opencode-dark.svg"
          }
        }
      ],
      "opencode-web.moreMenu": [
        {
          "command": "opencode-web.toggleSidebar",
          "group": "1_actions@1"
        },
        {
          "command": "opencode-web.openInBrowser",
          "group": "1_actions@2"
        },
        {
          "command": "opencode-web.showHelp",
          "group": "1_actions@3"
        },
        {
          "submenu": "opencode-web.processManagementMenu",
          "group": "2_process@1"
        }
      ],
      "opencode-web.processManagementMenu": [
        {
          "command": "opencode-web.restartProcess",
          "group": "1_restart@1"
        },
        {
          "command": "opencode-web.killProcess",
          "group": "1_restart@2"
        }
      ],
      "editor/context": [
        {
          "command": "opencode-web.appendCode",
          "when": "editorHasSelection",
          "group": "opencode"
        }
      ]
    },
    "configuration": {
      "title": "OpenCode",
      "properties": {
        "opencode.port": {
          "type": "number",
          "default": 4099,
          "description": "OpenCode server port"
        },
        "opencode.timeout": {
          "type": "number",
          "default": 5000,
          "description": "Connection timeout (ms)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "test-compile": "tsc -p ./",
    "test-watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "14.x",
    "@types/vscode": "^1.64.0",
    "@typescript-eslint/eslint-plugin": "^4.26.0",
    "@typescript-eslint/parser": "^4.26.0",
    "eslint": "^7.27.0",
    "ts-loader": "^9.2.2",
    "typescript": "^4.3.2",
    "webpack": "^5.38.1",
    "webpack-cli": "^4.7.0"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  }
}
